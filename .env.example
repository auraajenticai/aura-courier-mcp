# Aura Courier MCP — credentials (Bring-Your-Own, per merchant).
# Copy to .env and fill with YOUR courier merchant credentials. Never commit .env.

# --- Steadfast (Packzy) ---
# Get these from the Steadfast merchant portal → API settings.
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=

# --- Pathao (Merchant API) ---
# Get these from the Pathao Merchant panel → Developer/API. Use PATHAO_SANDBOX=true while testing.
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
PATHAO_USERNAME=
PATHAO_PASSWORD=
PATHAO_SANDBOX=false
# Optional default store so create_parcel doesn't need storeId every time:
PATHAO_STORE_ID=
