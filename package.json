{
  "name": "@aura/courier-mcp",
  "version": "0.1.0",
  "description": "Aura Courier MCP — one Model Context Protocol connector for every Bangladesh courier (Steadfast first; Pathao, RedX, Paperfly as pluggable adapters).",
  "type": "module",
  "bin": {
    "aura-courier-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev:http": "tsx src/http.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "courier",
    "bangladesh",
    "steadfast",
    "pathao",
    "logistics",
    "e-commerce",
    "aura"
  ],
  "author": "Aura Agentic AI",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
